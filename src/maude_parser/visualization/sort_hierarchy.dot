digraph SortHierarchy {
  rankdir=BT;  // Bottom to Top
  node [shape=box, style=rounded, fontname="Helvetica"];
  edge [arrowhead=empty];

  "Actor" [fillcolor="#E8F4F8", style="rounded,filled"];
  "ActorConfig" [fillcolor="#E8F4F8", style="rounded,filled"];
  "AddrFloatEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "AddrFloatMap" [fillcolor="#F0F0F0", style="rounded,filled"];
  "AddrSet" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Address" [fillcolor="#E6F0FF", style="rounded,filled"];
  "Attribute" [fillcolor="#F0F0F0", style="rounded,filled"];
  "AttributeSet" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Cache" [fillcolor="#FFE6E6", style="rounded,filled"];
  "CacheEntry" [fillcolor="#FFE6E6", style="rounded,filled"];
  "Config" [fillcolor="#FFF4E6", style="rounded,filled"];
  "Content" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Id" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdAddrFloatEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdAddrFloatMap" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdAddrListEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdAddrListMap" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdFloatEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdFloatMap" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdList" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdNatEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "IdNatMap" [fillcolor="#F0F0F0", style="rounded,filled"];
  "LabelForest" [fillcolor="#F0F0F0", style="rounded,filled"];
  "LabelTree" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Msg" [fillcolor="#E8F8E8", style="rounded,filled"];
  "Name" [fillcolor="#F8F8E8", style="rounded,filled"];
  "NameList" [fillcolor="#F8F8E8", style="rounded,filled"];
  "Nat" [fillcolor="#F0F0F0", style="rounded,filled"];
  "NodataCache" [fillcolor="#FFE6E6", style="rounded,filled"];
  "NodataEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "NxdomainCache" [fillcolor="#FFE6E6", style="rounded,filled"];
  "NxdomainEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Qid" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Query" [fillcolor="#E8F8F0", style="rounded,filled"];
  "QueryState" [fillcolor="#E8F8F0", style="rounded,filled"];
  "QueryStateSet" [fillcolor="#E8F8F0", style="rounded,filled"];
  "Queue" [fillcolor="#F0F0F0", style="rounded,filled"];
  "QueueEntry" [fillcolor="#F0F0F0", style="rounded,filled"];
  "RData" [fillcolor="#F0F0F0", style="rounded,filled"];
  "Response" [fillcolor="#F0E8F8", style="rounded,filled"];
  "TupleAddrQuery" [fillcolor="#E8F8F0", style="rounded,filled"];
  "TupleAddrQueryList" [fillcolor="#E8F8F0", style="rounded,filled"];
  "TupleAddrRecs" [fillcolor="#F0F0F0", style="rounded,filled"];
  "TupleAddrRecsSet" [fillcolor="#F0F0F0", style="rounded,filled"];
  "TupleAddrResp" [fillcolor="#F0F0F0", style="rounded,filled"];
  "TupleAddrRespList" [fillcolor="#F0F0F0", style="rounded,filled"];
  "TupleNameRecs" [fillcolor="#F8F8E8", style="rounded,filled"];
  "TupleNameRecsList" [fillcolor="#F8F8E8", style="rounded,filled"];
  "TupleSlistArgs" [fillcolor="#F0F0F0", style="rounded,filled"];
  "TupleSlistArgsList" [fillcolor="#F0F0F0", style="rounded,filled"];

  "Address" -> "AddrSet";
  "Msg" -> "Config";
  "Actor" -> "ActorConfig";
  "Attribute" -> "AttributeSet";
  "Name" -> "NameList";
  "Qid" -> "Name";
  "Nat" -> "Address";
  "Name" -> "RData";
  "Address" -> "RData";
  "CacheEntry" -> "Cache";
  "NxdomainEntry" -> "NxdomainCache";
  "NodataEntry" -> "NodataCache";
  "Nat" -> "Id";
  "Id" -> "IdList";
  "Query" -> "Content";
  "Response" -> "Content";
  "QueryState" -> "QueryStateSet";
  "IdNatEntry" -> "IdNatMap";
  "QueueEntry" -> "Queue";
  "AddrFloatEntry" -> "AddrFloatMap";
  "IdFloatEntry" -> "IdFloatMap";
  "IdAddrFloatEntry" -> "IdAddrFloatMap";
  "IdAddrListEntry" -> "IdAddrListMap";
  "TupleAddrQuery" -> "TupleAddrQueryList";
  "TupleAddrResp" -> "TupleAddrRespList";
  "TupleAddrRecs" -> "TupleAddrRecsSet";
  "TupleNameRecs" -> "TupleNameRecsList";
  "TupleSlistArgs" -> "TupleSlistArgsList";
  "LabelTree" -> "LabelForest";
}